# Railway Production Environment Variables
# 실제 배포 시 Railway 웹 UI에서 값 설정

NODE_ENV=production
PORT=3001

# MySQL Database (Railway)
DATABASE_URL=mysql://user:password@your-db-host.railway.internal:3306/stock_blog

# JWT Authentication
JWT_SECRET=your-strong-secret-key-at-least-32-characters-long
JWT_EXPIRATION=7d

# n8n Shared Secret (n8n Cloud와 동일한 값)
N8N_SECRET_KEY=your-n8n-cloud-shared-secret-key

# Claude/Anthropic API
ANTHROPIC_API_KEY=sk-ant-your-actual-api-key-here

# Frontend URL (Vercel 배포 도메인)
FRONTEND_URL=https://bigtrust.site

# Next.js ISR Revalidation Secret
REVALIDATE_SECRET=your-isr-revalidation-secret-key

# Logging
LOG_LEVEL=info
